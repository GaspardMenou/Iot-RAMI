# ─── Base de données (TimescaleDB / PostgreSQL) ───────────────────────────────
DB_CONTAINER_NAME=umons-sensor-db-dev
DB_VERSION=13
DB_HOST=localhost
DB_PORT=5432
DB_PORT_OUT=5432
DB_PORT_IN=5432
DB_USER=umons-sensor-dev
DB_PASSWORD=umons-sensor-dev
DB_NAME=umons-sensor-db-dev
DB_DIALECT=postgres

# ─── Serveur Node.js ──────────────────────────────────────────────────────────
NODE_ENV=development
NODE_PORT=3000
NODE_PORT_IN=3000
NODE_PORT_OUT=3000
NODE_CONTAINER_NAME=umons-sensor-dev

# ─── Authentification JWT ─────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=1d
BCRYPT_SALT_ROUNDS=10

REFRESH_TOKEN_EXPIRATION=7d
REFRESH_TOKEN_SECRET=refresh_secret

# ─── Frontend (CORS Socket.io) ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8080

# ─── Kafka ────────────────────────────────────────────────────────────────────
# En Docker : kafka:9092 | En local : localhost:9092
KAFKA_BROKERS=kafka:9092

# ─── Mail (optionnel) ─────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=
MAIL_PASSWORD=
