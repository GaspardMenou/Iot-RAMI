# ─── MQTT (Mosquitto local) ───────────────────────────────────────────────────
MQTT_URL=mqtt://localhost
MQTT_PORT=1883
MQTT_USERNAME=fog1
MQTT_PASSWORD=change-me

# ─── Kafka (backend cloud) ────────────────────────────────────────────────────
# Format : host:port  (ex: monserveur.com:9092)
KAFKA_BROKERS=localhost:9092

# ─── Buffer fog → Kafka ───────────────────────────────────────────────────────
# Intervalle de flush en ms (défaut 200ms — réduit la latence end-to-end)
FLUSH_INTERVAL_MS=200
# Taille max du buffer avant flush forcé (défaut 50 mesures)
FLUSH_MAX_SIZE=50
